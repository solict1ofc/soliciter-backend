{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@workspace/db": ["./lib/db/src/index.ts"],
      "@workspace/db/schema": ["./lib/db/src/schema/index.ts"]
    }
  },
  "include": ["src/**/*", "lib/**/*"]
}
