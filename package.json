{
  "name": "solicite",
  "version": "1.0.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm install --prefix server && node server/build.mjs",
    "start": "node index.js",
    "dev:api": "pnpm --filter @workspace/api-server run dev",
    "dev:admin": "pnpm --filter @workspace/admin run dev",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --if-present run typecheck"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  }
}
